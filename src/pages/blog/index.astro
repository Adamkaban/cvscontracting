---
import { getCollection } from 'astro:content'
import SiteLayout from '../../layouts/SiteLayout.astro'
import Breadcrumb from '../../components/common/Breadcrumb.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---
<SiteLayout
  title="Blog: Contractor Cost Guides & How-Tos"
  description="Cost guides, how-tos, and comparisons for foundations, basement waterproofing, excavation, and snow removal across Maine and New Hampshire."
  canonicalUrl="/blog"
>
  <div class="container section max-w-3xl">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />
    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 tracking-tight">Blog</h1>
    <p class="text-base text-gray-600 leading-relaxed mt-3">
      Cost guides and practical advice for Northeast homeowners.
    </p>

    <ul class="mt-8 divide-y divide-gray-200 border-t border-gray-200">
      {posts.map((post) => (
        <li class="py-6">
          <p class="text-xs text-gray-500">{fmt(post.data.pubDate)}</p>
          <h2 class="text-xl font-semibold text-gray-900 mt-1">
            <a href={`/blog/${post.id}`} class="hover:text-blue-700">{post.data.title}</a>
          </h2>
          <p class="text-gray-600 mt-1">{post.data.description}</p>
        </li>
      ))}
    </ul>
  </div>
</SiteLayout>
