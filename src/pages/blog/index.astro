---
import { getCollection } from 'astro:content'
import SiteLayout from '../../layouts/SiteLayout.astro'
import Breadcrumb from '../../components/common/Breadcrumb.astro'
import Eyebrow from '../../components/common/Eyebrow.astro'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
)

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
---
<SiteLayout
  title="Contractor Cost Guides & How-Tos | CVS Contracting"
  description="Cost guides, how-tos, and comparisons for foundations, basement waterproofing, excavation, and snow removal across Maine and New Hampshire."
  canonicalUrl="/blog"
>
  <div class="container py-16 max-w-3xl">
    <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />
    <Eyebrow text="Blog" />
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight text-ink mt-2">Contractor Cost Guides for Maine & New Hampshire</h1>
    <p class="text-base text-gray-600 leading-relaxed mt-3">
      Cost guides and practical advice for Northeast homeowners. We cover <a href="/foundation-repair" class="text-blue-700 hover:underline">foundation repair</a>, <a href="/basement-waterproofing" class="text-blue-700 hover:underline">basement waterproofing</a>, <a href="/excavation-contractors" class="text-blue-700 hover:underline">excavation</a>, and <a href="/snow-removal" class="text-blue-700 hover:underline">snow removal</a> — with real pricing data from Maine and New Hampshire contractors. Each guide includes average costs, what drives the final quote, and how to compare licensed contractors in your area.
    </p>

    <ul class="mt-8 space-y-4">
      {posts.map((post) => (
        <li>
          <a
            href={`/blog/${post.id}`}
            class="block rounded-xl border border-line bg-white p-6 hover:border-blue-700"
          >
            <p class="num text-xs text-gray-500">{fmt(post.data.pubDate)}</p>
            <p class="text-lg font-semibold text-ink mt-1">{post.data.title}</p>
            <p class="text-gray-600 mt-1 text-sm leading-relaxed">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</SiteLayout>
