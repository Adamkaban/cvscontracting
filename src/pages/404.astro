---
import SiteLayout from '../layouts/SiteLayout.astro'
---
<SiteLayout
  title="Page Not Found | CVS Contracting"
  description="The page you're looking for doesn't exist."
  noindex={true}
>
  <section class="container py-24 text-center">
    <p class="text-sm font-medium uppercase tracking-widest text-brand">404</p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-ink">Page not found</h1>
    <p class="mt-4 text-gray-600">That page doesn't exist or was moved.</p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-md bg-brand px-6 py-3 text-sm font-semibold text-white hover:bg-brand-dark transition-colors duration-150"
    >
      Go to homepage
    </a>
  </section>
</SiteLayout>
