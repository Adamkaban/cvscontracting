---
interface Props {
  serviceSlug: string
  serviceName: string
}

const { serviceSlug, serviceName } = Astro.props
---
<div class="rounded-xl border border-line bg-tint p-6 my-6">
  <p class="font-semibold text-ink">Find {serviceName} Contractors in Your City</p>
  <p class="text-sm text-gray-600 mt-1">
    Browse vetted local companies, ratings, and cost ranges by city.
  </p>
  <a
    href={`/${serviceSlug}`}
    class="inline-block mt-4 rounded-md bg-blue-700 px-6 py-3 font-semibold text-white hover:bg-blue-800"
  >
    Get Free Quotes
  </a>
</div>
