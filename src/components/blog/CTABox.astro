---
interface Props {
  serviceSlug: string
  serviceName: string
}

const { serviceSlug, serviceName } = Astro.props
---
<div class="bg-blue-50 border border-blue-200 rounded-lg p-4 my-6">
  <p class="font-semibold text-gray-900">Find {serviceName} Contractors in Your City</p>
  <p class="text-sm text-gray-600 mt-1">
    Browse vetted local companies, ratings, and cost ranges by city.
  </p>
  <a href={`/${serviceSlug}`} class="inline-block mt-3 text-blue-700 font-semibold hover:underline">
    See {serviceName} contractors →
  </a>
</div>
