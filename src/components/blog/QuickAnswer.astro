---
interface Props {
  items: string[]
}

const { items } = Astro.props
---
<div class="rounded-xl border border-line bg-tint p-5 my-6">
  <p class="text-xs font-semibold uppercase tracking-wide text-blue-700">Quick Answer</p>
  <ul class="mt-2 space-y-1 text-gray-700">
    {items.map((item) => (
      <li class="flex gap-2">
        <span class="text-blue-700 font-bold" aria-hidden="true">·</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
</div>
