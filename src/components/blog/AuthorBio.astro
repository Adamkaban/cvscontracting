---
interface Props {
  author: string
}

const { author } = Astro.props
---
<div class="rounded-xl border border-line bg-white p-5 mt-10">
  <p class="text-sm text-gray-600">
    <span class="font-semibold text-ink">{author}</span> covers home improvement and
    contractor services across Northeast USA.
  </p>
</div>
