---
import config from '../../../site.config.ts'
import Monogram from '../common/Monogram.astro'
import Badge from '../common/Badge.astro'
import CTAButton from '../common/CTAButton.astro'
import type { CompanyEntry } from '../../types'

interface Props {
  company: CompanyEntry
  rank: number
  affiliateUrl: string
  affiliateRel: string
}
const { company, rank, affiliateUrl, affiliateRel } = Astro.props

const full = Math.floor(company.rating)
const frac = company.rating - full
const hasHalf = frac >= 0.25 && frac < 0.75
const fullCount = full + (frac >= 0.75 ? 1 : 0)
const emptyCount = 5 - fullCount - (hasHalf ? 1 : 0)

const STAR = 'M239.2,97.29a16,16,0,0,0-13.81-11L166,81.17,142.72,25.81h0a15.95,15.95,0,0,0-29.44,0L90.07,81.17,30.61,86.32a16,16,0,0,0-9.11,28.06L66.61,153.8,53.09,212.34a16,16,0,0,0,23.84,17.34l51-31,51.11,31a16,16,0,0,0,23.84-17.34l-13.51-58.6,45.1-39.36A16,16,0,0,0,239.2,97.29Z'
const STAR_HALF = 'M239.2,97.29a16,16,0,0,0-13.81-11L166,81.17,142.72,25.81h0a15.95,15.95,0,0,0-29.44,0L90.07,81.17,30.61,86.32a16,16,0,0,0-9.11,28.06L66.61,153.8,53.09,212.34a16,16,0,0,0,23.84,17.34l51-31,51.11,31a16,16,0,0,0,23.84-17.34l-13.51-58.6,45.1-39.36A16,16,0,0,0,239.2,97.29ZM128,168a8,8,0,0,0-4.15,1.15L82.79,194,93.71,146.65a8,8,0,0,0-2.6-8L54.59,106.85l47.94-4.15a8,8,0,0,0,6.75-4.92L128,53.49Z'
---
<article class="relative rounded-xl border border-line bg-white p-5 transition-shadow duration-150 hover:border-l-4 hover:border-l-blue-700 hover:shadow-sm">
  <div class="flex items-start gap-4">
    <span class="num shrink-0 text-sm font-semibold text-gray-400 pt-1 w-6">#{rank}</span>
    <Monogram name={company.name} logo={company.logo_url} />
    <div class="min-w-0 flex-1">
      <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
        <h3 class="text-lg font-semibold text-ink truncate">
          {company.name}
        </h3>
      </div>

      <div class="mt-1 flex items-center gap-2">
        <span class="flex" aria-hidden="true">
          {Array.from({ length: fullCount }).map(() => (
            <svg class="fill-amber-400 text-amber-400" width="15" height="15" viewBox="0 0 256 256"><path d={STAR} /></svg>
          ))}
          {hasHalf && <svg class="fill-amber-400 text-amber-400" width="15" height="15" viewBox="0 0 256 256"><path d={STAR_HALF} /></svg>}
          {Array.from({ length: emptyCount }).map(() => (
            <svg class="fill-gray-200 text-gray-200" width="15" height="15" viewBox="0 0 256 256"><path d={STAR} /></svg>
          ))}
        </span>
        <span class="num text-sm font-semibold text-gray-900">{company.rating.toFixed(1)}</span>
        <span class="text-sm text-gray-500"><span class="num">{company.review_count}</span> reviews</span>
      </div>

      {(company.years_in_business || company.bbb_rating || company.insured || company.service_area) && (
        <div class="mt-2 flex flex-wrap gap-1.5">
          {company.years_in_business && <Badge><span class="num">{company.years_in_business}+</span> yrs</Badge>}
          {company.bbb_rating && <Badge variant="success">BBB {company.bbb_rating}</Badge>}
          {company.insured && <Badge variant="success">Insured*</Badge>}
          {company.service_area && <Badge>Serves {company.service_area}</Badge>}
        </div>
      )}

      {company.blurb && <p class="mt-2 text-sm text-gray-600 leading-relaxed">{company.blurb}</p>}

      <div class="mt-4 flex flex-col gap-3 border-t border-line pt-3 sm:flex-row sm:items-center sm:justify-between">
        {company.phone
          ? <a href={`tel:${company.phone}`} class="num text-sm text-gray-700">{company.phone}</a>
          : <span class="text-sm text-gray-400">Phone via quote</span>}
        <CTAButton href={affiliateUrl} rel={affiliateRel} class="w-full px-4 py-2 text-sm sm:w-auto">
          {config.affiliate.ctaText}
        </CTAButton>
      </div>
    </div>
  </div>
</article>
