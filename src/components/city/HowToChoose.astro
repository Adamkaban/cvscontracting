---
// Shared across all city pages — identical guidance is a component, not duplicate content.
const points = [
  {
    title: 'Verify license and insurance',
    body: 'Confirm the contractor carries current liability insurance and any license your state requires before work begins.',
  },
  {
    title: 'Check references and reviews',
    body: 'Ask for recent local references and read independent reviews, not just testimonials on the company site.',
  },
  {
    title: 'Get written estimates',
    body: 'Collect at least three written, itemized estimates so you can compare scope and price on equal terms.',
  },
  {
    title: 'Confirm warranties in writing',
    body: 'Ask what the workmanship and material warranties cover, and whether the warranty is transferable.',
  },
  {
    title: 'Avoid large upfront deposits',
    body: 'Be cautious of any contractor demanding full payment before work starts. Tie payments to milestones.',
  },
]
---
<section class="mt-10">
  <h2 class="text-2xl font-semibold text-ink tracking-tight">
    How to Choose a Contractor
  </h2>
  <ul class="mt-4 space-y-3">
    {points.map((p) => (
      <li class="flex gap-2">
        <svg
          class="mt-0.5 shrink-0 text-green-700"
          width="16"
          height="16"
          viewBox="0 0 256 256"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M173.66,98.34a8,8,0,0,1,0,11.32l-56,56a8,8,0,0,1-11.32,0l-24-24a8,8,0,0,1,11.32-11.32L112,148.69l50.34-50.35A8,8,0,0,1,173.66,98.34ZM232,128A104,104,0,1,1,128,24,104.11,104.11,0,0,1,232,128Zm-16,0a88,88,0,1,0-88,88A88.1,88.1,0,0,0,216,128Z" />
        </svg>
        <span>
          <span class="font-semibold text-ink">{p.title}.</span>
          <span class="text-gray-600"> {p.body}</span>
        </span>
      </li>
    ))}
  </ul>
</section>
