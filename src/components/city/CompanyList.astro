---
import type { CompanyEntry } from '../../types'
import CompanyCard from './CompanyCard.astro'
import CTAButton from '../common/CTAButton.astro'

interface Props {
  companies: CompanyEntry[]
  cityName: string
  serviceName: string
  affiliateUrl: string
  affiliateRel: string
}

const { companies, cityName, serviceName, affiliateUrl, affiliateRel } = Astro.props
---
<section>
  <h2 class="text-2xl font-semibold text-ink tracking-tight">
    Top {serviceName} Contractors in {cityName}
  </h2>
  <div class="space-y-4 mt-4">
    {companies.map((company, i) => (
      <CompanyCard company={company} rank={i + 1} affiliateUrl={affiliateUrl} affiliateRel={affiliateRel} />
    ))}
  </div>

  <div class="mt-6 bg-tint border border-line rounded-xl p-6 text-center">
    <p class="text-lg font-semibold text-ink">
      Get Free Quotes from {cityName} Contractors
    </p>
    <p class="text-sm text-gray-600 mt-1">
      Compare local pros and prices in minutes. Free, no obligation.
    </p>
    <CTAButton href={affiliateUrl} rel={affiliateRel} class="mt-4 px-6 py-3">
      Get Free Quotes
    </CTAButton>
  </div>
</section>
