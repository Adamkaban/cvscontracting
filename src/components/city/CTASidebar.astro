---
import config from '../../../site.config.ts'

interface Props {
  cityName: string
  costMin: number
  costMax: number
  affiliateUrl: string
  affiliateRel: string
}

const { cityName, costMin, costMax, affiliateUrl, affiliateRel } = Astro.props
---
<aside class="sticky top-20 rounded-xl border border-line bg-white p-6 shadow-sm">
  <p class="text-lg font-semibold text-ink">Get Free Quotes in {cityName}</p>
  <p class="text-sm text-gray-500 mt-3">Typical local cost</p>
  <p class="num text-2xl font-bold text-gray-900">
    ${costMin.toLocaleString()}–${costMax.toLocaleString()}
  </p>
  <a
    href={affiliateUrl}
    rel={affiliateRel}
    class="mt-4 block w-full rounded-md bg-blue-700 px-6 py-3 text-center font-semibold text-white hover:bg-blue-800"
  >
    {config.affiliate.ctaText}
  </a>
  <p class="mt-2 text-center text-xs text-gray-500">Free quotes, no obligation</p>
</aside>
