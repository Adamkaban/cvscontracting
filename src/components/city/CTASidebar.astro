---
import config from '../../../site.config.ts'

interface Props {
  cityName: string
  costMin: number
  costMax: number
  affiliateUrl: string
  affiliateRel: string
}

const { cityName, costMin, costMax, affiliateUrl, affiliateRel } = Astro.props
---
<aside class="sticky top-6 bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
  <p class="text-lg font-semibold text-gray-900">Get Free Quotes in {cityName}</p>
  <p class="text-sm text-gray-500 mt-3">Typical local cost</p>
  <p class="text-2xl font-bold text-gray-900">
    ${costMin.toLocaleString()}–${costMax.toLocaleString()}
  </p>
  <a
    href={affiliateUrl}
    rel={affiliateRel}
    class="block w-full text-center mt-4 bg-blue-700 hover:bg-blue-800 text-white font-semibold rounded-md px-6 py-3"
  >
    {config.affiliate.ctaText}
  </a>
  <p class="text-xs text-gray-500 text-center mt-2">Free quotes, no obligation</p>
</aside>
