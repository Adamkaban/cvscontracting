---
interface Props {
  rows: Array<{ state: string; avgCost: string; range: string }>
}

const { rows } = Astro.props
---
<div class="overflow-x-auto">
  <table class="w-full text-left border border-gray-200 rounded-lg border-separate border-spacing-0">
    <thead>
      <tr class="bg-gray-50 text-gray-900">
        <th class="px-4 py-3 text-sm font-semibold border-b border-gray-200">State</th>
        <th class="px-4 py-3 text-sm font-semibold border-b border-gray-200">Average Cost</th>
        <th class="px-4 py-3 text-sm font-semibold border-b border-gray-200">Typical Range</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row, i) => (
        <tr class={i % 2 === 1 ? 'bg-gray-50' : 'bg-white'}>
          <td class="px-4 py-3 text-sm font-medium text-gray-900 border-b border-gray-200">{row.state}</td>
          <td class="px-4 py-3 text-sm text-gray-700 border-b border-gray-200 font-mono">{row.avgCost}</td>
          <td class="px-4 py-3 text-sm text-gray-700 border-b border-gray-200 font-mono">{row.range}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
