---
interface Props {
  serviceName: string
  signs: string[]
  diyVsPro: string
}

const { serviceName, signs, diyVsPro } = Astro.props
---
<section class="mt-10">
  <h2 class="text-2xl font-semibold text-ink tracking-tight">
    When Do You Need {serviceName}?
  </h2>
  <p class="text-gray-600 mt-2">Common signs it is time to call a contractor:</p>
  <ul class="mt-3 space-y-3">
    {signs.map((s) => (
      <li class="rounded-xl border border-line bg-white p-4 flex gap-3 text-gray-600">
        <span class="text-amber-500 font-bold shrink-0" aria-hidden="true">!</span>
        <span>{s}</span>
      </li>
    ))}
  </ul>
  <p class="text-gray-600 leading-relaxed mt-6">{diyVsPro}</p>
</section>
