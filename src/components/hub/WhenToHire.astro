---
interface Props {
  serviceName: string
  signs: string[]
  diyVsPro: string
}

const { serviceName, signs, diyVsPro } = Astro.props
---
<section class="mt-10">
  <h2 class="text-2xl font-semibold text-gray-900 tracking-tight">
    When Do You Need {serviceName}?
  </h2>
  <p class="text-gray-600 mt-2">Common signs it is time to call a contractor:</p>
  <ul class="mt-3 space-y-2 text-gray-600">
    {signs.map((s) => (
      <li class="flex gap-2">
        <span class="text-amber-500 font-bold" aria-hidden="true">!</span>
        <span>{s}</span>
      </li>
    ))}
  </ul>
  <p class="text-gray-600 leading-relaxed mt-4">{diyVsPro}</p>
</section>
