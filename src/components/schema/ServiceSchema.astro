---
import config from '../../../site.config.ts'

interface Props {
  serviceName: string
  cityName?: string
  stateAbbr?: string
}

const { serviceName, cityName, stateAbbr } = Astro.props

const siteUrl = (import.meta.env.SITE_URL ?? config.seo.siteUrl).replace(/\/$/, '')

const areaServed = cityName
  ? { '@type': 'City', name: cityName, ...(stateAbbr ? { addressRegion: stateAbbr } : {}) }
  : { '@type': 'AdministrativeArea', name: 'Northeast US' }

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: serviceName,
  areaServed,
  provider: {
    '@type': 'Organization',
    '@id': siteUrl + '/#organization',
  },
}
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
