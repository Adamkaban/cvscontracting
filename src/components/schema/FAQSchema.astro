---
interface Props {
  faqs: Array<{ question: string; answer: string }>
}

const { faqs } = Astro.props

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
}
---
{faqs.length > 0 && (
  <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
